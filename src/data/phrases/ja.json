[
  {
    "id": "ja-1",
    "text": "こんにちは、お元気ですか？",
    "translations": {
      "pt": "Olá, como você está?",
      "en": "Hello, how are you?"
    }
  },
  {
    "id": "ja-2",
    "text": "おはようございます。",
    "translations": {
      "pt": "Bom dia.",
      "en": "Good morning."
    }
  },
  {
    "id": "ja-3",
    "text": "どうもありがとうございます。",
    "translations": {
      "pt": "Muito obrigado.",
      "en": "Thank you very much."
    }
  },
  {
    "id": "ja-4",
    "text": "もう一度言ってください。",
    "translations": {
      "pt": "Por favor, repita isso.",
      "en": "Please repeat that."
    }
  },
  {
    "id": "ja-5",
    "text": "この言語を勉強しています。",
    "translations": {
      "pt": "Eu estou aprendendo este idioma.",
      "en": "I am learning this language."
    }
  },
  {
    "id": "ja-6",
    "text": "駅はどこですか？",
    "translations": {
      "pt": "Onde fica a estação de trem?",
      "en": "Where is the train station?"
    }
  },
  {
    "id": "ja-7",
    "text": "コーヒーを一杯お願いします。",
    "translations": {
      "pt": "Eu gostaria de um café, por favor.",
      "en": "I would like a coffee, please."
    }
  },
  {
    "id": "ja-8",
    "text": "これはいくらですか？",
    "translations": {
      "pt": "Quanto custa isso?",
      "en": "How much does this cost?"
    }
  },
  {
    "id": "ja-9",
    "text": "手伝ってもらえますか？",
    "translations": {
      "pt": "Você pode me ajudar?",
      "en": "Could you help me?"
    }
  },
  {
    "id": "ja-10",
    "text": "また明日。",
    "translations": {
      "pt": "Até amanhã.",
      "en": "See you tomorrow."
    }
  }
]
