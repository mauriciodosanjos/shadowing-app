[
  {
    "id": "de-1",
    "text": "Hallo, wie geht es dir?",
    "translations": {
      "pt": "Olá, como você está?",
      "en": "Hello, how are you?"
    }
  },
  {
    "id": "de-2",
    "text": "Guten Morgen.",
    "translations": {
      "pt": "Bom dia.",
      "en": "Good morning."
    }
  },
  {
    "id": "de-3",
    "text": "Vielen Dank.",
    "translations": {
      "pt": "Muito obrigado.",
      "en": "Thank you very much."
    }
  },
  {
    "id": "de-4",
    "text": "Bitte wiederholen Sie das.",
    "translations": {
      "pt": "Por favor, repita isso.",
      "en": "Please repeat that."
    }
  },
  {
    "id": "de-5",
    "text": "Ich lerne diese Sprache.",
    "translations": {
      "pt": "Eu estou aprendendo este idioma.",
      "en": "I am learning this language."
    }
  },
  {
    "id": "de-6",
    "text": "Wo ist der Bahnhof?",
    "translations": {
      "pt": "Onde fica a estação de trem?",
      "en": "Where is the train station?"
    }
  },
  {
    "id": "de-7",
    "text": "Ich hätte gern einen Kaffee, bitte.",
    "translations": {
      "pt": "Eu gostaria de um café, por favor.",
      "en": "I would like a coffee, please."
    }
  },
  {
    "id": "de-8",
    "text": "Wie viel kostet das?",
    "translations": {
      "pt": "Quanto custa isso?",
      "en": "How much does this cost?"
    }
  },
  {
    "id": "de-9",
    "text": "Können Sie mir helfen?",
    "translations": {
      "pt": "Você pode me ajudar?",
      "en": "Could you help me?"
    }
  },
  {
    "id": "de-10",
    "text": "Bis morgen.",
    "translations": {
      "pt": "Até amanhã.",
      "en": "See you tomorrow."
    }
  }
]
